APP_ENV=development
APP_NAME=DayPlanner Backend
API_V1_PREFIX=/api/v1
APP_SECRET_KEY=change-me-to-64-char-random-string
APP_ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql://dayplanner:password@localhost:5432/dayplanner_db
REDIS_URL=redis://:password@localhost:6379/0
# 32-byte key in base64 (e.g. openssl rand -base64 32) or 64-char hex
ENCRYPTION_KEY=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:9002/auth
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CALENDAR_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:9002

ENABLE_BACKGROUND_SYNC=false
BACKGROUND_SYNC_INTERVAL_SECONDS=300
ENABLE_BACKGROUND_SYNC_LEADER_LOCK=true
BACKGROUND_SYNC_LEADER_LOCK_ID=424242

CORS_ALLOW_ORIGINS=http://localhost:9002,http://localhost:3000

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=dayplanner-backend
